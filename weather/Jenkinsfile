pipeline {
    agent any

    environment {
        DOCKER_HUB_CREDS = credentials('docker-hub-credentials')
        DOCKER_HUB_REPO = 'bobby01151'
        BACKEND_IMAGE = "${DOCKER_HUB_REPO}/weather-backend:latest"
        FRONTEND_IMAGE = "${DOCKER_HUB_REPO}/weather-frontend:latest"
        BACKEND_REPO = 'https://github.com/BOBBY01151/WeatherApp-SpringBoot-Backend.git'
        FRONTEND_REPO = 'https://github.com/BOBBY01151/WeatherApp-React-Frontend.git'
    }

    stages {
        stage('Checkout Repos') {
            steps {
                parallel(
                    'Backend Repo': {
                        dir('WeatherApp-backend') {
                            git url: "${BACKEND_REPO}", branch: 'main', credentialsId: 'github-credentials'
                        }
                    },
                    'Frontend Repo': {
                        dir('WeatherApp-frontend') {
                            git url: "${FRONTEND_REPO}", branch: 'main', credentialsId: 'github-credentials'
                        }
                    }
                )
            }
        }

        stage('Build Backend') {
            agent {
                docker { image 'maven:3.9.6-eclipse-temurin-17-alpine' }
            }
            steps {
                dir('WeatherApp-backend') {
                    sh 'mvn clean package -DskipTests'
                }
            }
        }

        stage('Build Frontend') {
            agent {
                docker { image 'node:20-alpine' }
            }
            steps {
                dir('WeatherApp-frontend') {
                    sh 'npm install'
                    sh 'npm run build'
                }
            }
        }

        stage('Docker Build Images') {
            steps {
                dir('WeatherApp-backend') {
                    sh "docker build -t ${BACKEND_IMAGE} ."
                }
                dir('WeatherApp-frontend') {
                    sh "docker build -t ${FRONTEND_IMAGE} ."
                }
            }
        }

        stage('Security Scan') {
            steps {
                parallel(
                    'Scan Backend': {
                        sh "docker run --rm -v /var/run/docker.sock:/var/run/docker.sock aquasec/trivy image --exit-code 0 ${BACKEND_IMAGE}"
                    },
                    'Scan Frontend': {
                        sh "docker run --rm -v /var/run/docker.sock:/var/run/docker.sock aquasec/trivy image --exit-code 0 ${FRONTEND_IMAGE}"
                    }
                )
            }
        }

        stage('Push Images to Docker Hub') {
            steps {
                script {
                    withCredentials([usernamePassword(credentialsId: 'docker-hub-credentials', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                        sh "echo ${DOCKER_PASS} | docker login -u ${DOCKER_USER} --password-stdin"
                        sh "docker push ${BACKEND_IMAGE}"
                        sh "docker push ${FRONTEND_IMAGE}"
                    }
                }
            }
        }

        stage('Deploy with Docker Compose') {
            steps {
                // Make sure docker-compose.yml points to the pushed Docker Hub images
                sh 'docker-compose -f ../WeatherApp-compose/docker-compose.yml up -d'
            }
        }
    }

    post {
        success {
            echo 'Pipeline finished successfully! Cleaning old images...'
            // Remove old backend/frontend images except latest
            sh """
                docker images ${DOCKER_HUB_REPO}/weather-backend --format '{{.ID}} {{.Repository}}:{{.Tag}}' | grep -v latest | awk '{print \$1}' | xargs -r docker rmi -f || true
                docker images ${DOCKER_HUB_REPO}/weather-frontend --format '{{.ID}} {{.Repository}}:{{.Tag}}' | grep -v latest | awk '{print \$1}' | xargs -r docker rmi -f || true
                docker image prune -f
            """
        }
        always {
            cleanWs()
            echo 'Workspace cleaned.'
        }
        failure {
            echo 'Pipeline failed. Check logs.'
        }
    }
}